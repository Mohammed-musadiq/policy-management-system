PRG="$0"

while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG="$(dirname "$PRG")/$link"
  fi
done

SAVED="$(pwd)"
MAVEN_PROJECTBASEDIR="$(dirname "$PRG")"
cd "$MAVEN_PROJECTBASEDIR" || exit 1
MAVEN_PROJECTBASEDIR="$(pwd -P)"
cd "$SAVED" || exit 1

if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD="java"
fi

if ! "$JAVACMD" -version >/dev/null 2>&1; then
  echo "Error: JAVA_HOME is not defined correctly."
  echo "Java 21 is required to run this project."
  exit 1
fi

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

if [ ! -r "$WRAPPER_JAR" ]; then
  echo "Maven wrapper jar not found: $WRAPPER_JAR"
  echo "Please ensure .mvn/wrapper/maven-wrapper.jar exists."
  exit 1
fi

exec "$JAVACMD" \
  -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" \
  -classpath "$WRAPPER_JAR" \
  "$WRAPPER_LAUNCHER" "$@"
